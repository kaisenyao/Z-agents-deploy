# LLM / model providers
# REQUIRED when MODEL_SET=gemini with OpenRouter routing enabled by current code.
OPENROUTER_API_KEY=

# OPTIONAL. Required only if MODEL_SET=openai and direct OpenAI routing is used.
OPENAI_API_KEY=

# OPTIONAL. Required only if MODEL_SET=anthropic and direct Anthropic routing is used.
ANTHROPIC_API_KEY=

# OPTIONAL. Required only if MODEL_SET=gemini and direct Google routing is used.
GOOGLE_API_KEY=

# OPTIONAL. Supported values in Z-App/src/z_app/app.py: gemini, openai, anthropic.
MODEL_SET=gemini
SUPERVISOR_LLM=google/gemini-3-flash-preview
QUANT_LLM=google/gemini-3-flash-preview
RESEARCH_LLM=google/gemini-3-flash-preview
RISK_LLM=google/gemini-3-flash-preview

# External APIs
# REQUIRED for ResearchAgent web_search tool.
TAVILY_API_KEY=

# REQUIRED for ResearchAgent polygon_stock_data tool.
POLYGON_API_KEY=

# REQUIRED for ResearchAgent finnhub_data tool.
FINNHUB_API_KEY=

# OPTIONAL. QuantAgent currently has a hard-coded Alpha Vantage key; replace code before relying on this.
ALPHA_VANTAGE_API_KEY=

# LangSmith
# OPTIONAL.
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=z-agents-railway

# Auth
# OPTIONAL for backend LangGraph API because current LangGraph auth is noop.
LANGGRAPH_AUTH_TYPE=noop

# REQUIRED only for the Z-UI Vite dev auth middleware, not for the LangGraph backend container.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# System config
# REQUIRED on Railway; Railway injects PORT automatically.
PORT=2024

# OPTIONAL. Comma-separated frontend origins. Use * for capstone/demo deploys.
CORS_ALLOW_ORIGINS=*

# OPTIONAL. Mount Railway volume here for Phase 1 file persistence.
LANGGRAPH_STATE_DIR=/app/Z-App/.langgraph_api

# OPTIONAL. Use in Phase 2 when moving LangGraph runtime state to managed services.
DATABASE_URI=
REDIS_URI=

# Frontend
# REQUIRED for static production frontend if it is deployed separately from the backend.
VITE_LANGGRAPH_API_BASE_URL=

# OPTIONAL. Only useful after market/auth middleware is moved out of Vite dev server.
VITE_APP_API_BASE_URL=

# REQUIRED for Z-UI Supabase Auth.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=